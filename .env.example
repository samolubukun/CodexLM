# Convex Configuration
CONVEX_DEPLOYMENT=your_convex_deployment_id
NEXT_PUBLIC_CONVEX_URL=your_convex_url

# Storage: DigitalOcean Spaces (S3 Compatible)
SPACES_KEY=your_do_spaces_key
SPACES_SECRET=your_do_spaces_secret
SPACES_BUCKET=your_bucket_name
SPACES_REGION=your_region_code
SPACES_ENDPOINT=your_spaces_endpoint

# Auth: Stack Auth
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your_stack_publishable_key
STACK_SECRET_SERVER_KEY=your_stack_secret_key
STACK_AUTH_URL=https://api.stack-auth.com/api/v1

# AI & LLM Engine
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_id
CLOUDFLARE_API_KEY=your_cloudflare_api_key

# Vector Database (Semantic Search)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=your_index_name
PINECONE_INDEX_HOST=your_pinecone_index_host_url

# Audio: Deepgram (Transcription & TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_HOST_MODEL=aura-2-thalia-en
DEEPGRAM_EXPERT_MODEL=aura-2-arcas-en

# Search: LangSearch
LANGSEARCH_API_KEY=your_langsearch_api_key

# YouTube: Transcript API (Supadata)
SUPADATA_API_KEY=your_supadata_api_key
